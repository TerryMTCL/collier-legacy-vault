# =========================================
# Collier Legacy Vault — Environment Variables
# =========================================
# Copy this file to .env.local for local development
# For production, use Cloudflare Workers secrets:
#   wrangler secret put <KEY_NAME>

# -------------------------
# REQUIRED — Security
# -------------------------

# JWT secret for admin session tokens (generate with: openssl rand -base64 64)
JWT_SECRET=your-very-long-random-secret-here-at-least-64-chars

# AES-256-GCM encryption key for vault data (must be exactly 64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here-0000000000000000000000000000

# -------------------------
# REQUIRED — Email
# -------------------------

# Resend API key (from resend.com dashboard)
RESEND_API_KEY=re_your_resend_api_key_here

# Email from address (must be verified with Resend)
FROM_EMAIL=noreply@jcollier-legacy.com

# -------------------------
# REQUIRED — Application
# -------------------------

# The public URL of the application (no trailing slash)
APP_URL=https://jcollier-legacy.com

# -------------------------
# OPTIONAL — Notifications
# -------------------------

# Telegram bot token for Josh's notifications
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Secret for protecting the cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# -------------------------
# LOCAL DEV ONLY
# -------------------------
NODE_ENV=development
